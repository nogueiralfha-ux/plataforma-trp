rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(therapistId) {
      return isAuthenticated() && request.auth.uid == therapistId;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == 'nogueiralfha@gmail.com';
    }

    match /therapists/{therapistId} {
      allow read: if isOwner(therapistId) || isAdmin();
      allow create: if isOwner(therapistId) || isAdmin();
      allow update: if isOwner(therapistId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /patients/{patientId} {
      allow read: if (isAuthenticated() && resource.data.therapistId == request.auth.uid) || isAdmin();
      allow create: if (isAuthenticated() &&
        request.resource.data.therapistId == request.auth.uid &&
        request.resource.data.keys().hasAll(['therapistId', 'name', 'createdAt'])) || isAdmin();
      allow update: if (isAuthenticated() &&
        resource.data.therapistId == request.auth.uid &&
        request.resource.data.therapistId == request.auth.uid &&
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['therapistId', 'createdAt']))) || isAdmin();
      allow delete: if (isAuthenticated() && resource.data.therapistId == request.auth.uid) || isAdmin();
    }

    match /anamneses/{anamneseId} {
      allow read: if (isAuthenticated() && resource.data.therapistId == request.auth.uid) || isAdmin();
      allow create: if (isAuthenticated() &&
        request.resource.data.therapistId == request.auth.uid &&
        request.resource.data.keys().hasAll(['therapistId', 'patientId', 'data', 'createdAt'])) || isAdmin();
      allow update: if (isAuthenticated() &&
        resource.data.therapistId == request.auth.uid &&
        request.resource.data.therapistId == request.auth.uid &&
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['therapistId', 'patientId', 'createdAt']))) || isAdmin();
      allow delete: if (isAuthenticated() && resource.data.therapistId == request.auth.uid) || isAdmin();
    }
  }
}
